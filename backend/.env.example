APP_NAME=VibeBoard
DEBUG=false

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vibeboard
SECRET_KEY=change-me-to-a-long-random-string

# Optional: JWT access token (defaults: HS256, 30 minutes)
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional: JWT refresh token TTL in days (default 30; must exceed access token lifetime)
# REFRESH_TOKEN_EXPIRE_DAYS=30

# Optional: Alembic (psycopg) connect timeout in seconds if DB is unreachable (default 10)
# ALEMBIC_CONNECT_TIMEOUT_SECONDS=10

STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
