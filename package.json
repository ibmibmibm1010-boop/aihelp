{
  "name": "react-skeleton",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "aibddck/helloword"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:worker": "npm run dev -w helloword",
    "dev:all": "concurrently -k -n vite,worker -c cyan,magenta \"vite\" \"npm run dev -w helloword\"",
    "build": "tsc --noEmit && vite build",
    "deploy:cf": "npm run build && wrangler deploy",
    "deploy:cf:worker": "npm run deploy -w helloword",
    "deploy:cf:all": "npm run build && wrangler deploy && npm run deploy -w helloword",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:signin": "playwright test e2e/sign-in-email.spec.ts",
    "test:e2e:smoke": "playwright test --grep-invert последовательно",
    "test:e2e:ui": "playwright test --ui",
    "supabase:relax-auth-limits": "node scripts/supabase-relax-auth-limits.mjs",
    "db:apply-boards": "node scripts/apply-boards-migration.mjs",
    "db:apply-board-members": "node scripts/apply-board-members-migration.mjs",
    "db:fix-boards-rls": "node scripts/apply-fix-boards-rls.mjs",
    "db:apply-tasks": "node scripts/apply-tasks-migration.mjs",
    "db:apply-board-columns": "node scripts/apply-board-columns-migration.mjs",
    "db:apply-board-column-section": "node scripts/apply-board-column-section-migration.mjs",
    "db:apply-profiles": "node scripts/apply-profiles-migration.mjs",
    "db:apply-task-card-color": "node scripts/apply-task-card-color-migration.mjs",
    "db:apply-task-attachments": "node scripts/apply-task-attachments-migration.mjs",
    "db:apply-billing-payments": "node scripts/apply-billing-payments-migration.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.103.0",
    "axios": "^1.14.0",
    "i18next": "^26.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.3",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.0",
    "dotenv": "^17.4.2",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2",
    "wrangler": "^4.84.1"
  }
}
